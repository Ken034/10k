# SEC EDGAR API requires a descriptive User-Agent (name + email)
SEC_USER_AGENT="YourName yourname@example.com"

# Qwen / DashScope configuration
QWEN_BASE_URL=https://ws-0exjku32k70c5ir6.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-api-key-here
QWEN_MODEL=qwen3.7-plus

# Background pre-fetch of S&P 500 companies
PREFETCH_ENABLED=true

# Environment: development or production
ENVIRONMENT=production
